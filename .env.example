# ─── Econ Studio — environment variables ──────────────────────────────────────
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
#   cp .env.example .env
#
# Supabase project (auth + feedback). Use your own project or ask the maintainer.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Anthropic API key — dev only, used when VITE_AI_PROXY_ENABLED=false
# (direct browser call; never expose a real key in production builds).
VITE_ANTHROPIC_KEY=sk-ant-...

# AI egress mode:
#   false = direct browser call with VITE_ANTHROPIC_KEY (local dev)
#   true  = /api/anthropic Vercel Function with JWT (production)
VITE_AI_PROXY_ENABLED=false

# Service-role key — backend only (feedback-collector agent). Do NOT prefix with
# VITE_; that would expose it to the browser bundle. Leave blank for local dev.
SUPABASE_SERVICE_ROLE_KEY=
